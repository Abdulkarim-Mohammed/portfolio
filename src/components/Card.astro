---
interface Props {
  isDark?: boolean;
  imageUrl?: string;
  contentDirection?: "row" | "col";
  class?: string;
}

const { isDark = false, imageUrl, contentDirection = "col", class: className = "" } = Astro.props;
---

<div class:list={[
  "group bg-[#171e2d] border border-slate-800 rounded-2xl overflow-hidden transition-all duration-300 hover:border-[var(--color-primary)] flex flex-col",
  className
]}>
  {imageUrl && (
    <div class="aspect-video w-full overflow-hidden bg-slate-800">
      <img
        alt=""
        class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-105"
        src={imageUrl}
      />
    </div>
  )}
  <div class:list={[
    "p-6 flex-grow flex",
    contentDirection === "row" ? "flex-row items-center" : "flex-col"
  ]}>
    <slot />
  </div>
</div>
