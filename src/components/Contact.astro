---
import ButtonIcon from "./ButtonIcon.astro";
import type { Lang } from "@/i18n/translations";
import { t } from "@/i18n/translations";

interface Props {
  lang?: Lang;
}

const { lang = "en" } = Astro.props;
const tr = t(lang);
---

<section class="full-width bg-[#191925] text-light" id="contact">
  <div class="flex flex-col items-center justify-center text-center gap-6 max-w-[1200px] mx-auto px-4 sm:px-8 lg:px-16 xl:px-32 py-24 sm:py-32">
    <h2 data-reveal class="text-3xl sm:text-4xl md:text-5xl font-bold leading-tight">
      {tr.contact.headline}
    </h2>

    <p data-reveal data-delay="150" class="text-slate-300 leading-relaxed text-lg max-w-lg">
      {tr.contact.subheadline}
    </p>

    <a
      data-reveal data-delay="250"
      href="https://mail.google.com/mail/?view=cm&to=Abdulkarim.aljundubi@gmail.com"
      target="_blank"
      rel="noopener noreferrer"
      class="group text-slate-400 hover:text-accent transition-colors duration-200 text-base underline underline-offset-4 decoration-slate-700 group-hover:decoration-accent"
    >
      Abdulkarim.aljundubi@gmail.com
    </a>

    <div data-reveal data-delay="350" class="flex flex-wrap gap-3 justify-center mt-2">
      <ButtonIcon
        isBlank
        iconName="github"
        url="https://github.com/Abdulkarim-Mohammed"
        borderColor="var(--color-primary)"
        name="GitHub"
      />
      <ButtonIcon
        isBlank
        iconName="linkedin"
        url="https://www.linkedin.com/in/abdulkarim-aljundubi-8299ba399/"
        borderColor="var(--color-primary)"
        name="LinkedIn"
      />
    </div>
  </div>
</section>
