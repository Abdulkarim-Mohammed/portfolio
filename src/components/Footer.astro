---
import { Icon } from "astro-icon/components";
import type { Lang } from "@/i18n/translations";
import { t } from "@/i18n/translations";

interface Props {
	lang?: Lang;
}

const { lang = 'en' } = Astro.props;
const tr = t(lang);
const currentYear = new Date().getFullYear();

const socials = [
	{ href: "https://www.linkedin.com/in/abdulkarim-aljundubi-8299ba399/", icon: "linkedin", label: "LinkedIn" },
	{ href: "https://github.com/Abdulkarim-Mohammed",                      icon: "github",   label: "GitHub"   },
	{ href: "mailto:Abdulkarim.aljundubi@gmail.com",                       icon: "envelope", label: "Email"    },
];
---

<footer class="relative z-10 bg-[#171e2d] text-light border-t border-slate-800">
	<div class="relative max-w-[1200px] mx-auto px-4 py-4 z-10 flex flex-col-reverse sm:grid sm:grid-cols-3 items-center gap-3 sm:gap-0">
		<p class="text-slate-400 text-sm text-center sm:text-left">
			{tr.hero.name} &copy; {currentYear}
		</p>
		<div class="flex items-center gap-4 justify-center">
			{socials.map(({ href, icon, label }) => (
				<a
					href={href}
					target="_blank"
					rel="noopener noreferrer"
					aria-label={label}
					class="text-slate-500 hover:text-[var(--color-primary)] transition-colors duration-200"
				>
					<Icon name={icon} class="w-5 h-5 sm:w-4 sm:h-4" />
				</a>
			))}
		</div>
		<p class="text-slate-600 text-xs text-center sm:text-right">
			{tr.footer.builtWith}
			<a href="https://astro.build/" target="_blank" rel="noopener noreferrer" class="text-slate-500 hover:text-[var(--color-primary)] transition-colors">Astro</a>
			{tr.footer.and}
			<a href="https://tailwindcss.com/" target="_blank" rel="noopener noreferrer" class="text-slate-500 hover:text-[var(--color-primary)] transition-colors">Tailwind</a>
		</p>
	</div>
</footer>
