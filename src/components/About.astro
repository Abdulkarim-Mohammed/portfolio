---
import SectionLayout from "@/layouts/SectionLayout.astro";
import Card from "@/components/Card.astro";
import { Icon } from "astro-icon/components";
import type { Lang } from "@/i18n/translations";
import { t } from "@/i18n/translations";

interface Props {
	lang?: Lang;
}

const { lang = 'en' } = Astro.props;
const tr = t(lang);

const certifications = [
	{
		title: "Python",
		issuer: "Kaggle",
		icon: "/img/logos/kaggle_logo.png",
		link: "https://www.kaggle.com/learn/certification/abdulkarim98/python",
	},
];

const technologies = [
	{ name: "HTML",         icon: "devicon:html5"      },
	{ name: "CSS",          icon: "devicon:css3"       },
	{ name: "JavaScript",   icon: "devicon:javascript" },
	{ name: "React",        icon: "devicon:react"      },
	{ name: "Python",       icon: "devicon:python"     },
	{ name: "Java",         icon: "devicon:java"       },
	{ name: "MySQL",        icon: "devicon:mysql"      },
	{ name: "Git",          icon: "devicon:git"        },
	{ name: "GitHub",       icon: "devicon:github",  invert: true },
	{ name: "VS Code",      icon: "devicon:vscode"     },
	{ name: "Vercel",       icon: "devicon:vercel"     },
	{ name: "XAMPP",        icon: null                 },
];
---

<SectionLayout id="about" isDark={true}>
	<div data-reveal class="flex flex-row items-center gap-3 text-3xl sm:text-4xl">
		<span class="bg-dark text-accent p-2 rounded-lg">{tr.about.badge}</span>
		<h2>{tr.about.title}</h2>
	</div>

	<div class="grid grid-cols-1 lg:grid-cols-3 gap-8 lg:gap-10 my-5 mb-8">
		<div class="lg:col-span-2 flex flex-col justify-between gap-8">
			<div data-reveal>
				<Card isDark>
					<h3 class="text-2xl font-semibold mb-8">
						{tr.about.whoTitle}
					</h3>
					<div class="flex flex-col lg:flex-row justify-between gap-8 text-slate-300 leading-relaxed">
						<p set:html={tr.about.bio1} />
						<p set:html={tr.about.bio2} />
					</div>
				</Card>
			</div>
			<div class="grid grid-cols-1 md:grid-cols-2 gap-8">
				<div data-reveal data-delay="100">
					<Card isDark contentDirection="row">
						<div class="bg-[#1e293b] p-3 rounded-xl me-2">
							<Icon name="macbook" class="text-[var(--color-primary)] w-8 h-8" />
						</div>
						<div>
							<p class="text-xs uppercase tracking-wider font-semibold text-slate-500">
								{tr.about.workingAt}
							</p>
							<p class="text-white font-medium">{lang === 'ar' ? 'المدينة المنورة، السعودية' : 'Madinah, Saudi Arabia'}</p>
						</div>
					</Card>
				</div>
				<div data-reveal data-delay="200">
					<Card isDark contentDirection="row">
						<div class="bg-[#1e293b] p-3 rounded-xl me-2">
							<Icon name="student" class="text-[var(--color-primary)] w-8 h-8" />
						</div>
						<div>
							<p class="text-xs uppercase tracking-wider font-semibold text-slate-500">
								{tr.about.studyingAt}
							</p>
							<p class="text-white font-medium">{lang === 'ar' ? 'الجامعة الإسلامية' : 'Islamic Univ. of Madinah'}</p>
						</div>
					</Card>
				</div>
			</div>
		</div>
		<div class="lg:col-span-1" data-reveal data-delay="150">
			<Card isDark class="!my-0 flex-col">
				<h3 class="text-2xl mb-5 font-medium">{tr.about.certTitle}</h3>
				<div class="flex flex-col gap-4">
					{certifications.map((cert) => (
						<a
							href={cert.link}
							target="_blank"
							class="bg-[#1e293b] p-3 rounded-xl flex items-center gap-4 pointer hover:bg-[#28323f] transition-all ease"
						>
							<div class="w-10 h-10">
								<img class="rounded-lg" src={cert.icon} alt={cert.title} />
							</div>
							<div class="flex-grow">
								<h4 class="font-bold text-white">{cert.title}</h4>
								<p class="text-[11px] font-bold text-accent uppercase tracking-wider">{cert.issuer}</p>
							</div>
						</a>
					))}
				</div>
			</Card>
		</div>
	</div>

	<div data-reveal data-delay="100">
		<Card isDark>
			<h3 class="text-2xl font-semibold mb-8 text-center lg:text-start">{tr.about.techTitle}</h3>
			<div dir={tr.dir} class="flex flex-wrap gap-x-2 gap-y-4 justify-center lg:justify-start">
				{technologies.map((tech) => (
					<div class="flex items-center gap-2 px-4 py-2 border border-slate-700 rounded-xl bg-[#141820] hover:bg-[#28323f] transition-all ease cursor-default">
						{tech.icon && <Icon name={tech.icon} class={`w-5 h-5 ${tech.invert ? 'brightness-0 invert' : ''}`} />}
						<span>{tech.name}</span>
					</div>
				))}
			</div>
		</Card>
	</div>
</SectionLayout>

