---
import SectionLayout from "@/layouts/SectionLayout.astro";
import type { Lang } from "@/i18n/translations";
import { t } from "@/i18n/translations";

interface Props {
	lang?: Lang;
}

const { lang = 'en' } = Astro.props;
const tr = t(lang);
const experiences = tr.experience.items;
---

<SectionLayout id="experience" isDark={true}>
	<div data-reveal class="flex flex-row items-center gap-3 text-3xl sm:text-4xl">
		<span class="bg-dark text-accent p-2 rounded-lg">{tr.experience.badge}</span>
		<h2>{tr.experience.title}</h2>
	</div>
	<div class="relative mt-10">
		{
			experiences.map(({company, role, duration, description}, index) => {
				return (
					<div data-reveal data-delay={index * 150} class="relative space-y-12 ps-8 pb-8">
						{index !== experiences.length - 1 && <div class="absolute start-0 top-2 bottom-0 w-0.5 h-full bg-[var(--color-dark)]"></div>}
						<div class="relative">
							<div class={`absolute top-2 -start-[37px] w-3 h-3 rounded-full ${index === 0 ? "bg-[var(--color-primary)]" : "bg-slate-400"} z-10`}></div>
							<div class="flex flex-col md:flex-row md:items-start justify-between gap-4">
								<div>
									<h3 class="text-xl font-bold text-white">
										{company}
									</h3>
									<p class={`${index === 0 ? "text-accent" : "text-slate-400"} text-m font-regular mb-2`}>
										{role}
									</p>
								</div>
								<span class={`text-[14px] font-semibold text-slate-300 bg-white/5 px-3 py-1 ring-1 ${index === 0 ? "ring-[var(--color-primary)]" : "ring-slate-400"} rounded-lg w-fit mb-4 md:mb-0`}>
									{duration}
								</span>
							</div>
							<p class="mt-1 text-slate-300 max-w-3xl leading-relaxed" set:html={description}></p>
						</div>
					</div>
				);
			})
		}
	</div>
</SectionLayout>
