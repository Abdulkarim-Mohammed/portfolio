---
import SectionLayout from "@/layouts/SectionLayout.astro";
import ButtonIcon from "./ButtonIcon.astro";
import type { Lang } from "@/i18n/translations";
import { t } from "@/i18n/translations";

interface Props {
	lang?: Lang;
}

const { lang = 'en' } = Astro.props;
const tr = t(lang);
const projects = tr.projects.items;
---

<SectionLayout id="work" isDark={true}>
	<div data-reveal class="flex flex-row items-center gap-3 text-3xl z-1">
		<span class="bg-dark text-accent p-2 rounded-lg">{tr.projects.badge}</span>
		<h2 class="text-4xl">{tr.projects.title}</h2>
	</div>

	<div class="mt-10 space-y-8">
		<p data-reveal class="text-slate-300 leading-relaxed" set:html={tr.projects.intro} />
		<div class="grid grid-cols-1 sm:grid-cols-2 gap-8 max-w-4xl mx-auto">
			{
				projects.map(
					({
						title,
						description,
						technologies,
						imageUrl,
						link,
						github,
					}, index) => {
						return (
							<div data-reveal data-delay={index * 150} class="group bg-[#171e2d] border border-slate-800 rounded-2xl overflow-hidden transition-all duration-300 hover:border-slate-600 flex flex-col">
								<a class="aspect-video w-full overflow-hidden bg-slate-800" href={link} target="_blank" rel="noopener nofollow">
									<img
										alt={title}
										class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-105"
										src={imageUrl}
									/>
								</a>
								<div class="p-6 flex-grow flex flex-col">
									<div class="flex flex-wrap gap-2 mb-4">
										{technologies.map((tech) => (
											<span class="px-3 py-1 text-[10px] font-bold tracking-wider rounded-full bg-[#171e2d]/10 text-accent border border-[var(--color-primary)]/50">
												{tech}
											</span>
										))}
									</div>
									<h3 class="text-lg font-bold mb-3 text-white">
										{title}
									</h3>
									<p class="text-slate-400 text-sm leading-relaxed mb-6">
										{description}
									</p>
									<div class="flex gap-2 justify-start mt-auto">
										<ButtonIcon
											url={link}
											name={tr.projects.viewSite}
											iconName="new-window"
											isBlank
											animated
										/>
										<ButtonIcon
											url={github}
											name={tr.projects.viewRepo}
											iconName="github"
											isBlank
											animated
										/>
									</div>
								</div>
							</div>
						);
					},
				)
			}
		</div>
		<div class="flex items-center justify-center mt-6">
			<ButtonIcon
				isBlank
				url="https://github.com/Abdulkarim-Mohammed?tab=repositories"
				name={tr.projects.viewAll}
				borderColor="var(--color-primary)"
			/>
		</div>
	</div>
</SectionLayout>
