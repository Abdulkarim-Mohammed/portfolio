---
import { Icon } from 'astro-icon/components';

const { name, url, iconName, isBlank = false, animated = false, borderColor = "rgba(255, 255, 255, 0.3)" } = Astro.props;
---

<a href={ url } target={isBlank ? "_blank" : "_self"} style={`--custom-border-color: ${borderColor}`} class:list={[
	"text-dark px-4 py-2 rounded-3xl main-btn flex items-center overflow-hidden",
	animated ? "button-icon" : "gap-x-2"
]}>
	{iconName && <Icon name={iconName} class:list={["flex-shrink-0", animated && "icon-btn"]} />} 
	<span class:list={[animated && "button-text"]}>{name}</span>
</a>

<style>
	a {
		border-color: var(--custom-border-color);
	}
</style>
